# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGO_URI=mongodb://127.0.0.1:27017/rentnest

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_access_key_change_me_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_me_in_production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# SMTP Configuration (Email service)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=RentNest <noreply@rentnest.com>

# Cloudinary Configuration (Image upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend Client URL
FRONTEND_URL=http://localhost:5173
